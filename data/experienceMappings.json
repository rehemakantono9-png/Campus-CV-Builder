{\n  "class_representative": [\n    "Represented student concerns in class discussions and communicated key issues between students and lecturers.",\n    "Supported class coordination by sharing updates, collecting feedback, and promoting effective communication.",\n    "Assisted in organizing class activities and maintaining accurate records of student attendance and participation.",\n    "Facilitated communication between faculty and students, ensuring important announcements were effectively distributed."\n  ],\n  "school_project_group_lead": [\n    "Coordinated group activities, task sharing, and submission timelines during academic project work.",\n    "Supported project planning, teamwork, and presentation preparation for academic assignments.",\n    "Organized research tasks and ensured equitable distribution of work among team members.",\n    "Managed project documentation and coordinated final submission requirements."\n  ],\n  "mosque_or_church_volunteer": [\n    "Assisted with community programme coordination, volunteer support, and participant communication.",\n    "Supported event organization and service activities in a faith-based community setting.",\n    "Helped coordinate youth programs and community outreach initiatives.",\n    "Maintained communication with community members and assisted with administrative tasks."\n  ],\n  "small_online_business": [\n    "Managed small-scale sales activities, including customer communication, order handling, and basic promotion.",\n    "Built practical experience in client service, organization, and business communication.",\n    "Handled product listings, customer inquiries, and order processing through social media platforms.",\n    "Developed basic marketing materials and maintained customer relationship records."\n  ],\n  "event_usher_or_helper": [\n    "Supported event coordination through participant guidance, communication, and on-site organization.",\n    "Assisted with logistics and guest support during organized events.",\n    "Helped manage event flow, answered attendee questions, and directed participants to appropriate locations.",\n    "Coordinated with event staff to ensure smooth execution of scheduled activities."\n  ],\n  "social_media_page_admin": [\n    "Created and scheduled basic digital content to support online communication and audience engagement.",\n    "Managed page updates and responded to audience interactions across social media platforms.",\n    "Monitored engagement metrics and helped maintain consistent posting schedules.",\n    "Assisted in developing content strategies to increase follower engagement and reach."\n  ],\n  "tutor": [\n    "Provided academic support to learners through explanation of concepts and guided practice.",\n    "Strengthened communication and instructional skills by helping students understand course content.",\n    "Prepared learning materials and assessed student progress through regular evaluations.",\n    "Adapted teaching methods to accommodate different learning styles and abilities."\n  ],\n  "family_business_support": [\n    "Assisted in daily business operations, including customer service, inventory management, and record keeping.",\n    "Supported financial tracking and helped maintain organized business documentation.",\n    "Contributed to marketing efforts and helped improve customer communication channels.",\n    "Gained practical experience in small business management and operational efficiency."\n  ],\n  "research_assistant_volunteer": [\n    "Supported academic research through data collection, literature reviews, and documentation.",\n    "Assisted in organizing research materials and maintaining accurate reference records.",\n    "Helped prepare research summaries and contributed to data analysis tasks.",\n    "Coordinated with research team members to ensure timely completion of project milestones."\n  ],\n  "sports_team_coordinator": [\n    "Organized team schedules, communicated practice times, and coordinated match participation.",\n    "Supported team morale and helped maintain equipment inventory and records.",\n    "Assisted in arranging transportation and logistics for team events and competitions.",\n    "Facilitated communication between team members and coaching staff."\n  ],\n  "library_monitor": [\n    "Assisted library users with basic inquiries and maintained organized study spaces.",\n    "Supported circulation desk operations including check-ins, check-outs, and reshelving.",\n    "Helped enforce library policies and created a conducive study environment.",\n    "Assisted in inventory management and maintained accurate record of library materials."\n  ],\n  "orientation_guide": [\n    "Welcomed new students and provided guidance during campus orientation programs.",\n    "Assisted in coordinating orientation schedules and directing participants to appropriate venues.",\n    "Answered questions about campus facilities and helped new students navigate university services.",\n    "Supported event organizers with registration and information distribution."\n  ]\n}